{
  "name": "@charlesabear/slack-mcp-server",
  "version": "1.2.0",
  "description": "Model Context Protocol (MCP) server for Slack Workspaces, with Slack Canvas tools. Fork of korotovsky/slack-mcp-server. Supports Stdio and SSE transports, proxy settings and does not require any permissions or bots being created or approved by Workspace admins",
  "main": "bin/index.js",
  "bin": {
    "slack-mcp-server": "bin/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@charlesabear/slack-mcp-server-darwin-amd64": "1.2.0",
    "@charlesabear/slack-mcp-server-darwin-arm64": "1.2.0",
    "@charlesabear/slack-mcp-server-linux-amd64": "1.2.0",
    "@charlesabear/slack-mcp-server-linux-arm64": "1.2.0",
    "@charlesabear/slack-mcp-server-windows-amd64": "1.2.0",
    "@charlesabear/slack-mcp-server-windows-arm64": "1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CharlesABear/slack-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "slack",
    "slack-api",
    "slack-canvas",
    "model context protocol",
    "model",
    "context",
    "protocol"
  ],
  "author": {
    "name": "CharlesABear",
    "url": "https://github.com/CharlesABear"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CharlesABear/slack-mcp-server/issues"
  },
  "homepage": "https://github.com/CharlesABear/slack-mcp-server#readme"
}
